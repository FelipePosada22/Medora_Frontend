{
  "name": "medora",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "node scripts/start.mjs",
    "start:local": "ng serve --configuration=local",
    "start:dev": "ng serve --configuration=development",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "e2e": "cross-env E2E_ENV=local playwright test",
    "e2e:ui": "cross-env E2E_ENV=local playwright test --ui",
    "e2e:dev": "cross-env E2E_ENV=dev playwright test",
    "e2e:dev:ui": "cross-env E2E_ENV=dev playwright test --ui",
    "e2e:report": "playwright show-report playwright-report-local",
    "e2e:report:dev": "playwright show-report playwright-report-dev"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "dependencies": {
    "@angular/common": "^20.2.0",
    "@angular/compiler": "^20.2.0",
    "@angular/core": "^20.2.0",
    "@angular/forms": "^20.2.0",
    "@angular/platform-browser": "^20.2.0",
    "@angular/router": "^20.2.0",
    "jspdf": "^4.2.1",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^20.2.1",
    "@angular/cli": "^20.2.1",
    "@angular/compiler-cli": "^20.2.0",
    "@playwright/test": "^1.58.2",
    "@types/jasmine": "~5.1.0",
    "cross-env": "^10.1.0",
    "dotenv": "^17.3.1",
    "jasmine-core": "~5.9.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "typescript": "~5.9.2"
  }
}
